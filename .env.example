# Supabase
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...

# WhatsApp - seu número pessoal (quem recebe as mensagens do bot)
MAIN_USER_NUMBER=5592981134347
# Número da parceira (sem + e sem espaços)
PARTNER_NUMBER=

# Fuso horário
TIMEZONE=America/Manaus

# Caminho das sessões WhatsApp
SESSION_PATH=./sessions

# Puppeteer — Railway (Nixpacks) usa este path automaticamente
# NÃO ALTERE se estiver usando Railway
PUPPETEER_EXECUTABLE_PATH=/run/current-system/sw/bin/chromium

# Porta (Railway define automaticamente via variável PORT)
PORT=3000
